{
  "name": "tricore-events",
  "version": "1.0.0",
  "private": true,
  "main": "server.js",
  "scripts": {
    "atlas:dev-ip": "node scripts/ensure-atlas-dev-access.mjs --wait",
    "dev": "npm run atlas:dev-ip && npx concurrently \"node scripts/run-server-dev.mjs\" \"node scripts/wait-for-port.mjs && npm --prefix client run dev\"",
    "server": "node scripts/run-server-dev.mjs",
    "client": "npm --prefix client run dev",
    "build": "npm --prefix client run build",
    "build:client": "npm --prefix client run build",
    "hostinger:build": "npm run build:client",
    "hostinger:start": "node server.js",
    "seed:test:data": "node server/scripts/seed-test-data.js",
    "start": "node server.js",
    "start:server": "node server.js",
    "validate:workflow": "node server/scripts/run-validation-suite.js",
    "deploy": "npm run build:client && npm run start:server",
    "lint": "npm --prefix client run lint",
    "postinstall": "npm --prefix client install --include=dev && npm --prefix client run build"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "mongodb-memory-server": "^11.0.1"
  },
  "engines": {
    "node": "22.x"
  },
  "type": "module",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "file-stream-rotator": "^1.0.0",
    "google-auth-library": "^9.15.0",
    "helmet": "^8.0.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.0",
    "morgan": "^1.10.0",
    "nodemailer": "^8.0.3",
    "razorpay": "^2.9.4",
    "sharp": "^0.34.5",
    "zod": "^3.23.8"
  }
}
