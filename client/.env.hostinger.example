# Keep the API URL empty when the frontend and backend are served from the same Hostinger app.
VITE_API_URL=
VITE_API_ORIGIN=
VITE_GOOGLE_CLIENT_ID=your-production-google-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID_LOCALHOST=
VITE_GOOGLE_CLIENT_ID_LAN=
VITE_GOOGLE_CLIENT_ID_PUBLIC=your-production-google-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_IDS={"https://tricore.yourdomain.com":"your-production-google-client-id.apps.googleusercontent.com","https://www.tricore.yourdomain.com":"your-production-google-client-id.apps.googleusercontent.com"}
VITE_GOOGLE_ALLOWED_ORIGINS=https://tricore.yourdomain.com,https://www.tricore.yourdomain.com
