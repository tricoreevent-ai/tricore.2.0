VITE_API_URL=
# Optional backend origin for the Vite dev/preview proxy.
VITE_API_ORIGIN=http://localhost:5000
# Default Google Web client ID.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Optional origin-specific client IDs.
VITE_GOOGLE_CLIENT_ID_LOCALHOST=
VITE_GOOGLE_CLIENT_ID_LAN=
VITE_GOOGLE_CLIENT_ID_PUBLIC=
# Optional exact origin-to-client map in JSON, for example:
# {"http://localhost:5173":"client-id.apps.googleusercontent.com","https://app.example.com":"client-id.apps.googleusercontent.com"}
VITE_GOOGLE_CLIENT_IDS={}
# Keep this list aligned with Google Cloud Authorized JavaScript origins.
VITE_GOOGLE_ALLOWED_ORIGINS=http://localhost:5173,http://YOUR-LAN-IP:5173,http://localhost:5000,http://YOUR-LAN-IP:5000
