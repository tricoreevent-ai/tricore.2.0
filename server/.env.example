HOST=0.0.0.0
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/tricore-events
MONGODB_ALLOW_MEMORY_FALLBACK=true
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173,http://192.168.0.202:5173,http://localhost:5000,http://192.168.0.202:5000
# Primary Google Web client ID used by the frontend.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Optional extra Google client IDs that the backend should trust, comma separated.
GOOGLE_CLIENT_IDS=
CONTACT_FORWARD_EMAILS=team@tricoreevents.online
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tricore.event@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM_EMAIL=tricore.event@gmail.com
SMTP_FROM_NAME=TriCore Events
SMTP_TO_RECIPIENTS=team@tricoreevents.online
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# Optional: auto-add the current public IP to the Atlas project access list before local development starts.
ATLAS_DEV_AUTO_ALLOW_CURRENT_IP=false
ATLAS_PROJECT_ID=
ATLAS_PROJECT_NAME=
ATLAS_ORG_ID=
ATLAS_PUBLIC_KEY=
ATLAS_PRIVATE_KEY=
ATLAS_DEV_ACCESS_COMMENT_PREFIX=tricore-dev-auto
ATLAS_DEV_ACCESS_DELETE_STALE=true
ATLAS_DEV_ACCESS_WAIT_TIMEOUT_MS=90000
