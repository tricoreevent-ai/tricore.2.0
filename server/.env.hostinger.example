HOST=0.0.0.0
PORT=5000
MONGODB_URI=mongodb+srv://tricore_app:replace-with-strong-password@cluster0.example.mongodb.net/tricore-events?retryWrites=true&w=majority
MONGODB_ALLOW_MEMORY_FALLBACK=false
MONGODB_SERVER_SELECTION_TIMEOUT_MS=15000
JWT_SECRET=replace-with-a-long-random-secret-at-least-64-characters
JWT_EXPIRES_IN=7d
CLIENT_URL=https://tricore.yourdomain.com,https://www.tricore.yourdomain.com
GOOGLE_CLIENT_ID=your-production-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_IDS=
CONTACT_FORWARD_EMAILS=ops@yourdomain.com
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@yourdomain.com
SMTP_PASS=replace-with-your-mailbox-password
SMTP_FROM_EMAIL=no-reply@yourdomain.com
SMTP_FROM_NAME=TriCore Events
SMTP_TO_RECIPIENTS=ops@yourdomain.com
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxx
RAZORPAY_KEY_SECRET=replace-with-your-live-razorpay-secret
