                  "fill": "#A0A0A0",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "TriCore Events was born from a simple belief: every gathering has the potential to become something extraordinary. Founded by a team of event enthusiasts and sports lovers, we set out to redefine how communities come together through world-class event management.",
                  "lineHeight": 1.8,
                  "fontFamily": "Space Grotesk",
                  "fontSize": 15,
                  "fontWeight": "normal"
